// 🚀 Jenkinsfile - Pipeline de CI/CD para aplicación api-orders (Configurado para H2)
// 📦 Este pipeline automatiza el proceso de construcción, pruebas y despliegue

pipeline {
    agent any

    // 🛠️ Configuración de herramientas necesarias
    tools {
        maven 'MAVEN_HOME'
    }

    // 🔧 Definición de variables globales adaptadas a api-orders con H2
    environment {
        DOCKER_PROJECT_NAME = 'api_orders_h2_ctx'
        APP_CONTAINER_NAME = 'api_orders_app'
        // ✅ REPOSITORIO CONFIGURADO: Tu URL real de GitHub
        REPO_URL = 'https://github.com/OLDstep17/exam_order.git'
    }

    stages {
        // 📥 Etapa 1: Clonación limpia del repositorio remoto
        stage('Clone') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '🔄 === INICIO: CLONACIÓN DEL REPOSITORIO ==='
                    cleanWs()
                    git branch: 'master', url: "${REPO_URL}"
                    echo '✅ === FIN: CLONACIÓN COMPLETADA ==='
                }
            }
        }

        // 🏗️ Etapa 2: Construcción del proyecto
        stage('Build') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '🔨 === INICIO: CONSTRUCCIÓN DEL PROYECTO ==='
                    sh 'mvn -DskipTests clean package'
                    echo '✅ === FIN: CONSTRUCCIÓN COMPLETADA ==='
                }
            }
        }

        // 🧪 Etapa 3: Ejecución de pruebas (Crucial para Cucumber + JaCoCo)
        stage('Test') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '🧪 === INICIO: EJECUCIÓN DE PRUEBAS ==='
                    sh 'mvn test'
                    echo '✅ === FIN: PRUEBAS COMPLETADAS ==='
                }
            }
        }

        // 📊 Etapa 4: Análisis de calidad con SonarQube
        stage('Sonar Analysis') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '📊 === INICIO: ANÁLISIS DE CALIDAD ==='
                    withSonarQubeEnv('sonarqube') {
                        sh 'mvn org.sonarsource.scanner.maven:sonar-maven-plugin:3.9.0.2155:sonar -Pcoverage'
                    }
                    echo '✅ === FIN: ANÁLISIS DE CALIDAD COMPLETADO ==='
                }
            }
        }

        // 🎯 Etapa 5: Verificación de calidad
        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    echo '🎯 === VERIFICACIÓN DE ESTÁNDARES DE CALIDAD ==='
                    waitForQualityGate abortPipeline: true
                    echo '✅ === FIN: VERIFICACIÓN DE CALIDAD COMPLETADA ==='
                }
            }
        }

        // 🚀 Etapa 6: Despliegue de la aplicación mediante Docker Compose (Solo la App con H2)
        stage('Deploy Application') {
            steps {
                echo '🚀 === INICIO: PROCESO DE DESPLIEGUE ==='
                dir('docker') {
                    script {
                        // 🧹 Limpieza de despliegue anterior
                        echo '1️⃣ Limpiando despliegue anterior...'
                        try {
                            sh "docker-compose -p ${DOCKER_PROJECT_NAME} down -v --remove-orphans"
                        } catch (Exception e) {
                            echo "⚠️ Advertencia: ${e.getMessage()}"
                        }

                        // 🏗️ Construcción y levantamiento de la aplicación
                        echo '2️⃣ Construyendo y levantando contenedor de la aplicación...'
                        sh "docker-compose -p ${DOCKER_PROJECT_NAME} up -d --build"

                        // ⏳ Espera y verificación de la aplicación
                        echo '3️⃣ Esperando inicio de la aplicación...'
                        sleep(20)
                        echo '4️⃣ Mostrando logs de la aplicación:'
                        sh "docker logs --tail 200 ${APP_CONTAINER_NAME}"
                    }
                }
                echo '✅ === FIN: DESPLIEGUE COMPLETADO ==='
            }
        }
    }

    // 📝 Acciones post-ejecución
    post {
        always {
            echo '🏁 === FINALIZACIÓN DEL PIPELINE ==='
        }
        success {
            echo '🎉 ✓ Pipeline de api-orders (H2) completado exitosamente'
        }
        failure {
            echo '💥 ✗ Pipeline falló. Revisa los logs de la etapa afectada'
        }
    }
}